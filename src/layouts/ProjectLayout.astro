---
import BaseLayout from "./BaseLayout.astro";
import Navbar from "../components/layout/Navbar.astro";
import Footer from "../components/layout/Footer.astro";

interface Props {
  title: string;
  company: string;
  period: string;
  role: string;
  tags: string[];
  github?: string;
  sideProject?: boolean;
}

const { title, company, period, role, tags, github, sideProject } = Astro.props;
---

<BaseLayout title={`${title} | 김강남`}>
  <Navbar />
  <main class="mx-auto max-w-4xl px-6 pt-20 pb-16 lg:pt-12">
    <!-- Back link -->
    <a
      href="/"
      class="mb-8 inline-flex items-center gap-2 text-sm text-[var(--color-text-secondary)] transition-colors duration-200 hover:text-[var(--color-primary)]"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      메인으로 돌아가기
    </a>

    <!-- Header -->
    <header class="mb-12">
      <p class="mb-2 text-sm font-medium text-[var(--color-accent)]">
        {company} · {role}
      </p>
      <h1 class="mb-3 flex items-center gap-3 text-3xl font-extrabold md:text-4xl font-[family-name:var(--font-heading)]">
        {title}
        {github && (
          <a
            href={github}
            target="_blank"
            rel="noopener noreferrer"
            class="text-[var(--color-text-secondary)] transition-colors duration-200 hover:text-[var(--color-primary)]"
            aria-label="GitHub Repository"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
            </svg>
          </a>
        )}
        {sideProject && (
          <span class="rounded-full bg-emerald-500/15 px-3 py-1 text-xs font-semibold text-emerald-400">
            Side Project
          </span>
        )}
      </h1>
      <p class="mb-4 text-sm text-[var(--color-text-secondary)]">{period}</p>
      <div class="flex flex-wrap gap-2">
        {
          tags.map((tag) => (
            <span class="rounded-md bg-[var(--color-primary)]/10 px-3 py-1 text-xs text-[var(--color-primary)]">
              {tag}
            </span>
          ))
        }
      </div>
    </header>

    <!-- Content -->
    <article class="prose-custom">
      <slot />
    </article>
  </main>
  <Footer />
</BaseLayout>

<style>
  .prose-custom :global(h2) {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--color-text);
  }

  .prose-custom :global(h3) {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }

  .prose-custom :global(p) {
    color: var(--color-text-secondary);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .prose-custom :global(ul) {
    list-style: none;
    padding-left: 0;
    margin-bottom: 1.5rem;
  }

  .prose-custom :global(li) {
    color: var(--color-text-secondary);
    padding-left: 1.25rem;
    position: relative;
    margin-bottom: 0.5rem;
    line-height: 1.7;
  }

  .prose-custom :global(li::before) {
    content: "";
    position: absolute;
    left: 0;
    top: 0.7rem;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background-color: var(--color-primary);
  }

  .prose-custom :global(strong) {
    color: var(--color-text);
    font-weight: 600;
  }

  .prose-custom :global(code) {
    font-family: var(--font-mono);
    background: rgba(255, 255, 255, 0.05);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.875rem;
  }

  .prose-custom :global(img) {
    width: 100%;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    margin: 1rem 0;
  }

  .prose-custom :global(.demo-grid) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin: 1.5rem 0;
  }

  .prose-custom :global(.demo-item) {
    margin: 1.5rem 0;
  }

  .prose-custom :global(.demo-grid .demo-item) {
    margin: 0;
  }

  .prose-custom :global(.demo-item img) {
    margin: 0.5rem 0 0;
  }

  .prose-custom :global(.demo-label) {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-primary);
  }

  @media (max-width: 640px) {
    .prose-custom :global(.demo-grid) {
      grid-template-columns: 1fr;
    }
  }
</style>
