---
import BaseLayout from "./BaseLayout.astro";
import Navbar from "../components/layout/Navbar.astro";
import Footer from "../components/layout/Footer.astro";
import { t, localePath } from "../i18n/utils";
import type { Locale } from "../i18n/utils";

interface Props {
  title: string;
  company: string;
  period: string;
  role: string;
  tags: string[];
  github?: string;
  sideProject?: boolean;
  claudeCode?: boolean;
  locale?: Locale;
}

const { title, company, period, role, tags, github, sideProject, claudeCode, locale = "ko" } = Astro.props;
---

<BaseLayout title={`${title} | ${t("hero.name", locale)}`}>
  <Navbar locale={locale} />
  <!-- Hero Section -->
  <div class="project-hero">
    <div class="mx-auto max-w-4xl px-6 pt-20 pb-10 lg:pt-14">
      <a
        href={localePath("/projects", locale)}
        class="mb-6 inline-flex items-center gap-2 text-sm text-[var(--color-text-secondary)] transition-colors duration-200 hover:text-[var(--color-primary)]"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        {t("layout.backToProjects", locale)}
      </a>

      <p class="mb-3 text-sm font-medium tracking-wide uppercase text-[var(--color-accent)]">
        {company} · {role}
      </p>
      <h1 class="mb-4 flex flex-wrap items-center gap-3 text-3xl font-extrabold md:text-4xl font-[family-name:var(--font-heading)]">
        {title}
        {github && (
          <a
            href={github}
            target="_blank"
            rel="noopener noreferrer"
            class="text-[var(--color-text-secondary)] transition-colors duration-200 hover:text-[var(--color-primary)]"
            aria-label="GitHub Repository"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
            </svg>
          </a>
        )}
        {sideProject && (
          <span class="rounded-full bg-emerald-500/15 px-3 py-1 text-xs font-semibold text-emerald-400">
            Side Project
          </span>
        )}
        {claudeCode && (
          <span class="rounded-full bg-amber-500/15 px-3 py-1 text-xs font-semibold text-amber-400">
            Claude Code
          </span>
        )}
      </h1>
      <p class="mb-5 text-sm text-[var(--color-text-secondary)]">{period}</p>
      <div class="flex flex-wrap gap-2">
        {
          tags.map((tag) => (
            <span class="rounded-md bg-[var(--color-primary)]/10 px-3 py-1 text-xs text-[var(--color-primary)]">
              {tag}
            </span>
          ))
        }
      </div>
    </div>
  </div>

  <main class="mx-auto max-w-4xl px-6 pb-16">
    <!-- Content -->
    <article class="prose-custom">
      <slot />
    </article>
  </main>
  <Footer locale={locale} />
</BaseLayout>

<style>
  /* 1. Hero gradient background */
  .project-hero {
    background: linear-gradient(180deg, rgba(0, 212, 255, 0.04) 0%, transparent 100%);
    border-bottom: 1px solid var(--color-border);
  }

  :global(html.light) .project-hero {
    background: linear-gradient(180deg, rgba(0, 153, 204, 0.06) 0%, transparent 100%);
  }

  /* Base typography — optimized for readability */
  .prose-custom {
    font-size: 1.05rem;
    counter-reset: section-counter;
  }

  /* 2. Section numbering on H2 */
  .prose-custom :global(h2) {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    margin-top: 3.5rem;
    margin-bottom: 1.25rem;
    padding-top: 1.75rem;
    border-top: 1px solid var(--color-border);
    color: var(--color-text);
    counter-increment: section-counter;
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
  }

  .prose-custom :global(h2::before) {
    content: "0" counter(section-counter);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-primary);
    background: rgba(0, 212, 255, 0.1);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    flex-shrink: 0;
  }

  .prose-custom :global(h2:first-of-type) {
    border-top: none;
    padding-top: 0;
    margin-top: 2rem;
  }

  .prose-custom :global(h3) {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 600;
    margin-top: 2.25rem;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }

  .prose-custom :global(p) {
    color: var(--color-text-secondary);
    line-height: 1.85;
    margin-bottom: 1.25rem;
    letter-spacing: 0.01em;
  }

  .prose-custom :global(ul) {
    list-style: none;
    padding-left: 0;
    margin-bottom: 1.75rem;
  }

  .prose-custom :global(li) {
    color: var(--color-text-secondary);
    padding-left: 1.25rem;
    position: relative;
    margin-bottom: 0.75rem;
    line-height: 1.8;
  }

  .prose-custom :global(li::before) {
    content: "";
    position: absolute;
    left: 0;
    top: 0.75rem;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background-color: var(--color-primary);
  }

  .prose-custom :global(strong) {
    color: var(--color-text);
    font-weight: 600;
  }

  .prose-custom :global(code) {
    font-family: var(--font-mono);
    background: rgba(255, 255, 255, 0.05);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.875rem;
  }

  .prose-custom :global(img) {
    width: 100%;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    margin: 1rem 0;
  }

  .prose-custom :global(.demo-grid) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin: 1.5rem 0;
  }

  .prose-custom :global(.demo-item) {
    margin: 1.5rem 0;
  }

  .prose-custom :global(.demo-grid .demo-item) {
    margin: 0;
  }

  .prose-custom :global(.demo-item img) {
    margin: 0.5rem 0 0;
  }

  .prose-custom :global(.demo-label) {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-primary);
  }

  /* 1. Metric Cards */
  .prose-custom :global(.metric-cards) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 1rem;
    margin: 0.5rem 0 2.5rem;
  }

  .prose-custom :global(.metric-card) {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-top: 2px solid var(--color-primary);
    border-radius: 12px;
    padding: 1.25rem;
    text-align: center;
  }

  .prose-custom :global(.metric-card .value) {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1.2;
  }

  .prose-custom :global(.metric-card .label) {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    margin-top: 0.25rem;
  }

  /* 2. Highlight Box */
  .prose-custom :global(.highlight-box) {
    background: var(--color-surface);
    border-left: 3px solid transparent;
    border-image: linear-gradient(180deg, var(--color-primary), var(--color-secondary)) 1;
    border-radius: 0;
    padding: 1.25rem 1.5rem;
    margin: 1.75rem 0;
    color: var(--color-text-secondary);
    line-height: 1.8;
  }

  .prose-custom :global(.highlight-box strong) {
    color: var(--color-primary);
  }

  /* 3. Before/After Comparison */
  .prose-custom :global(.compare) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin: 1.25rem 0;
  }

  .prose-custom :global(.compare-item) {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 1rem 1.25rem;
  }

  .prose-custom :global(.compare-item.before) {
    border-top: 3px solid var(--color-text-secondary);
  }

  .prose-custom :global(.compare-item.after) {
    border-top: 3px solid var(--color-accent);
  }

  .prose-custom :global(.compare-item .tag) {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
    display: block;
  }

  .prose-custom :global(.compare-item.before .tag) {
    color: var(--color-text-secondary);
  }

  .prose-custom :global(.compare-item.after .tag) {
    color: var(--color-accent);
  }

  .prose-custom :global(.compare-item p) {
    margin: 0;
    font-size: 0.9rem;
  }

  /* 4. Process Flow */
  .prose-custom :global(.process-flow) {
    display: flex;
    align-items: center;
    gap: 0;
    margin: 1.5rem 0;
    overflow-x: auto;
    padding-bottom: 0.5rem;
  }

  .prose-custom :global(.process-step) {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 0.75rem 1rem;
    text-align: center;
    min-width: 100px;
    flex-shrink: 0;
  }

  .prose-custom :global(.process-step .step-title) {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .prose-custom :global(.process-step .step-desc) {
    font-size: 0.7rem;
    color: var(--color-text-secondary);
    margin-top: 0.2rem;
  }

  .prose-custom :global(.process-arrow) {
    color: var(--color-primary);
    font-size: 1.2rem;
    flex-shrink: 0;
    padding: 0 0.25rem;
  }

  /* 5. Bento Grid */
  .prose-custom :global(.bento-grid) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 0.75rem;
    margin: 1.25rem 0 1.75rem;
  }

  .prose-custom :global(.bento-item) {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .prose-custom :global(.bento-label) {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-primary);
  }

  .prose-custom :global(.bento-value) {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  /* Nested list bullet override */
  .prose-custom :global(.metric-card li::before),
  .prose-custom :global(.highlight-box li::before),
  .prose-custom :global(.compare-item li::before),
  .prose-custom :global(.process-step li::before) {
    display: none;
  }

  @media (max-width: 640px) {
    .prose-custom :global(.demo-grid) {
      grid-template-columns: 1fr;
    }
    .prose-custom :global(.compare) {
      grid-template-columns: 1fr;
    }
    .prose-custom :global(.process-flow) {
      flex-wrap: wrap;
      gap: 0.5rem;
    }
    .prose-custom :global(.process-arrow) {
      display: none;
    }
    .prose-custom :global(.metric-cards) {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
