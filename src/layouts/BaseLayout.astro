---
import "../styles/global.css";
import { t, localePath, defaultLocale } from "../i18n/utils";
import type { Locale } from "../i18n/utils";
import FloatingControls from "../components/ui/FloatingControls.astro";

interface Props {
  title: string;
  description?: string;
  locale?: Locale;
}

const { title, locale = defaultLocale } = Astro.props;
const description = Astro.props.description ?? t("layout.defaultDescription", locale);

const siteUrl = "https://kangnam7654.github.io";
const ogImage = `${siteUrl}/images/og-image.png`;
const ogSiteName = t("layout.ogSiteName", locale);

const langMap: Record<Locale, string> = { ko: "ko", en: "en", ja: "ja" };
---

<!doctype html>
<html lang={langMap[locale]}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- hreflang -->
    <link rel="alternate" hreflang="ko" href={`${siteUrl}${localePath(Astro.url.pathname, "ko")}`} />
    <link rel="alternate" hreflang="en" href={`${siteUrl}${localePath(Astro.url.pathname, "en")}`} />
    <link rel="alternate" hreflang="ja" href={`${siteUrl}${localePath(Astro.url.pathname, "ja")}`} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:site_name" content={ogSiteName} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <script is:inline>
      (function() {
        const theme = localStorage.getItem('theme');
        if (theme === 'light' || (!theme && window.matchMedia('(prefers-color-scheme: light)').matches)) {
          document.documentElement.classList.add('light');
        }
      })();
    </script>
  </head>
  <body class="min-h-screen overflow-x-hidden lg:pl-64">
    <FloatingControls locale={locale} />
    <slot />
  </body>
</html>
