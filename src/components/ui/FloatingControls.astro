---
import LanguageSwitcher from "./LanguageSwitcher.astro";
import type { Locale } from "../../i18n/utils";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<div
  id="floating-controls"
  class="fixed top-4 right-4 z-[60] flex items-center gap-2 rounded-full border border-[var(--color-border)] bg-[var(--color-bg)]/80 px-3 py-1.5 backdrop-blur-xl shadow-lg transition-opacity duration-300"
>
  <LanguageSwitcher locale={locale} />
  <div class="h-4 w-px bg-[var(--color-border)]"></div>
  <button
    id="floating-theme-toggle"
    class="text-[var(--color-text-secondary)] transition-colors duration-200 hover:text-[var(--color-primary)]"
    aria-label="Toggle theme"
  >
    <svg id="floating-icon-sun" xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
    </svg>
    <svg id="floating-icon-moon" xmlns="http://www.w3.org/2000/svg" class="hidden h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
    </svg>
  </button>
</div>

<script>
  // Theme toggle
  function updateFloatingIcons() {
    const isLight = document.documentElement.classList.contains("light");
    document.getElementById("floating-icon-sun")?.classList.toggle("hidden", isLight);
    document.getElementById("floating-icon-moon")?.classList.toggle("hidden", !isLight);
  }

  document.getElementById("floating-theme-toggle")?.addEventListener("click", () => {
    document.documentElement.classList.toggle("light");
    const isLight = document.documentElement.classList.contains("light");
    localStorage.setItem("theme", isLight ? "light" : "dark");
    updateFloatingIcons();

    // Sync with sidebar/mobile toggles if they exist
    document.getElementById("icon-sun")?.classList.toggle("hidden", isLight);
    document.getElementById("icon-moon")?.classList.toggle("hidden", !isLight);
    document.getElementById("mobile-icon-sun")?.classList.toggle("hidden", isLight);
    document.getElementById("mobile-icon-moon")?.classList.toggle("hidden", !isLight);
  });

  updateFloatingIcons();
</script>
