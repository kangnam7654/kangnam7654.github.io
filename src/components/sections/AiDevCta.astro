---
import { t, localePath } from "../../i18n/utils";
import type { Locale } from "../../i18n/utils";

interface Props {
  locale?: Locale;
}

const { locale = "ko" } = Astro.props;

const stats = [
  { value: t("aiDevCta.stat1.value", locale), label: t("aiDevCta.stat1.label", locale) },
  { value: t("aiDevCta.stat2.value", locale), label: t("aiDevCta.stat2.label", locale) },
  { value: t("aiDevCta.stat3.value", locale), label: t("aiDevCta.stat3.label", locale) },
];
---

<section class="px-6 py-24">
  <div class="mx-auto max-w-3xl text-center">
    <div class="rounded-2xl border border-[var(--color-accent)]/20 bg-[var(--color-accent)]/5 px-8 py-12">
      <p class="mb-2 text-sm font-semibold uppercase tracking-widest text-[var(--color-accent)]">
        {t("aiDevCta.label", locale)}
      </p>
      <h3 class="mb-4 text-2xl font-bold md:text-3xl font-[family-name:var(--font-heading)]">
        {t("aiDevCta.title", locale)}
      </h3>
      <p class="mb-8 text-[var(--color-text-secondary)]">
        {t("aiDevCta.description", locale)}
      </p>
      <div class="mb-8 grid grid-cols-3 gap-4">
        {stats.map((stat) => (
          <div>
            <p class="text-2xl font-bold text-[var(--color-primary)] md:text-3xl">{stat.value}</p>
            <p class="text-xs text-[var(--color-text-secondary)]">{stat.label}</p>
          </div>
        ))}
      </div>
      <a
        href={localePath("/ai-dev", locale)}
        class="inline-block rounded-full bg-[var(--color-accent)] px-8 py-3 font-semibold text-[var(--color-bg)] transition-all duration-200 hover:scale-105 hover:shadow-[0_0_20px_rgba(6,255,165,0.3)]"
      >
        {t("aiDevCta.cta.aidev", locale)}
      </a>
    </div>
  </div>
</section>
