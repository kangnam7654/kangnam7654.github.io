---
import { t, localePath } from "../../i18n/utils";
import type { Locale } from "../../i18n/utils";
import LanguageSwitcher from "../ui/LanguageSwitcher.astro";

interface Props {
  locale?: Locale;
}

const { locale = "ko" } = Astro.props;

const resumeItems = [
  { label: "About", href: localePath("/#about", locale) },
  { label: "Experience", href: localePath("/#experience", locale) },
  { label: "Skills", href: localePath("/#skills", locale) },
  { label: "Education", href: localePath("/#education", locale) },
];

const projectItems = [
  { label: t("nav.project.ue5Mcp", locale), href: localePath("/projects/ue5-mcp", locale) },
  { label: t("nav.project.aiAssessment", locale), href: localePath("/projects/ai-assessment", locale) },
  { label: t("nav.project.faceToChar", locale), href: localePath("/projects/face-to-character", locale) },
  { label: t("nav.project.motionTracking", locale), href: localePath("/projects/motion-tracking", locale) },
  { label: t("nav.project.recommender", locale), href: localePath("/projects/recommender", locale) },
  { label: t("nav.project.radarDetection", locale), href: localePath("/projects/radar-detection", locale) },
  { label: t("nav.project.anomalyDetection", locale), href: localePath("/projects/anomaly-detection", locale) },
  { label: t("nav.project.matchingPlatform", locale), href: localePath("/projects/matching-platform", locale) },
  { label: t("nav.project.kangnamClient", locale), href: localePath("/projects/kangnam-client", locale) },
  { label: t("nav.project.autoShorts", locale), href: localePath("/projects/auto-shorts", locale) },
  { label: t("nav.project.whatHealth", locale), href: localePath("/projects/what-health", locale) },
  { label: t("nav.project.dalgyeol", locale), href: localePath("/projects/dalgyeol", locale) },
  { label: t("nav.project.quorum", locale), href: localePath("/projects/quorum", locale) },
  { label: t("nav.project.gameNpc", locale), href: localePath("/projects/game-npc", locale) },
  { label: t("nav.project.storyWriter", locale), href: localePath("/projects/story-writer", locale) },
];
---

<!-- Desktop Sidebar -->
<aside
  id="sidebar"
  class="fixed left-0 top-0 z-50 hidden h-screen w-64 flex-col justify-between border-r border-[var(--color-border)] bg-[var(--color-bg)]/80 px-6 py-8 backdrop-blur-xl lg:flex overflow-y-auto"
>
  <div>
    <!-- Profile -->
    <a href={localePath("/", locale)} class="mb-6 block">
      <div class="mb-1 text-xl font-extrabold tracking-tight font-[family-name:var(--font-heading)]">
        {t("hero.name", locale)}
      </div>
      <div class="text-sm text-[var(--color-primary)]">
        {t("hero.role", locale)}
      </div>
    </a>

    <!-- Resume Category -->
    <div class="mb-6">
      <div class="flex w-full items-center justify-between rounded-lg px-3 py-2 text-sm font-bold uppercase tracking-widest text-[var(--color-text)]">
        <a href={localePath("/", locale)} class="transition-colors duration-200 hover:text-[var(--color-primary)]">{t("nav.resume", locale)}</a>
        <button
          id="resume-toggle"
          class="transition-colors duration-200 hover:text-[var(--color-primary)]"
          aria-label={t("nav.ariaResumeToggle", locale)}
        >
          <svg id="resume-chevron" xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
      </div>
      <nav id="resume-menu" class="mt-1 flex flex-col gap-0.5 pl-2">
        {
          resumeItems.map((item) => (
            <a
              href={item.href}
              class="nav-link rounded-lg px-3 py-1.5 text-sm text-[var(--color-text-secondary)] transition-all duration-200 hover:bg-white/5 hover:text-[var(--color-primary)]"
              data-section={item.href.replace(/^\/(en|ja)?\/?(#?)/, "").replace("#", "")}
            >
              {item.label}
            </a>
          ))
        }
      </nav>
    </div>

    <!-- AI Dev -->
    <a
      href={localePath("/ai-dev", locale)}
      class="mt-4 block rounded-lg px-3 py-2 text-sm font-bold uppercase tracking-widest text-[var(--color-text)] transition-colors duration-200 hover:bg-white/5 hover:text-[var(--color-primary)]"
    >
      {t("nav.aiDev", locale)}
    </a>

    <!-- Projects Category -->
    <div class="mt-4 mb-2">
      <div class="flex w-full items-center justify-between rounded-lg px-3 py-2 text-sm font-bold uppercase tracking-widest text-[var(--color-text)]">
        <a href={localePath("/projects", locale)} class="transition-colors duration-200 hover:text-[var(--color-primary)]">{t("nav.projects", locale)}</a>
        <button
          id="projects-toggle"
          class="transition-colors duration-200 hover:text-[var(--color-primary)]"
          aria-label={t("nav.ariaProjectsToggle", locale)}
        >
          <svg id="projects-chevron" xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
      </div>
      <nav id="projects-menu" class="mt-1 flex flex-col gap-0.5 pl-2">
        {
          projectItems.map((item) => (
            <a
              href={item.href}
              class="rounded-lg px-3 py-1.5 text-sm text-[var(--color-text-secondary)] transition-all duration-200 hover:bg-white/5 hover:text-[var(--color-primary)]"
            >
              {item.label}
            </a>
          ))
        }
      </nav>
    </div>

    <!-- Contact -->
    <a
      href={localePath("/contact", locale)}
      class="nav-link mt-4 block rounded-lg px-3 py-2 text-sm font-bold uppercase tracking-widest text-[var(--color-text)] transition-colors duration-200 hover:bg-white/5 hover:text-[var(--color-primary)]"
      data-section="contact"
    >
      {t("nav.contact", locale)}
    </a>
  </div>

  <!-- Theme Toggle + Language Switcher + Social Links -->
  <div class="flex items-center gap-4 pt-4">
    <button
      id="theme-toggle"
      class="text-[var(--color-text-secondary)] transition-colors duration-200 hover:text-[var(--color-primary)]"
      aria-label={t("nav.ariaTheme", locale)}
    >
      <!-- Sun (shown in dark mode) -->
      <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
      </svg>
      <!-- Moon (shown in light mode) -->
      <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
      </svg>
    </button>
    <div class="h-4 w-px bg-[var(--color-border)]"></div>
    <LanguageSwitcher locale={locale} />
    <div class="h-4 w-px bg-[var(--color-border)]"></div>
    <a
      href="https://github.com/kangnam7654"
      target="_blank"
      rel="noopener noreferrer"
      class="text-[var(--color-text-secondary)] transition-colors duration-200 hover:text-[var(--color-primary)]"
      aria-label="GitHub"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
      </svg>
    </a>
    <a
      href="https://linkedin.com/in/kangnam7654"
      target="_blank"
      rel="noopener noreferrer"
      class="text-[var(--color-text-secondary)] transition-colors duration-200 hover:text-[var(--color-primary)]"
      aria-label="LinkedIn"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
      </svg>
    </a>
    <a
      href="mailto:kangnam7653@gmail.com"
      class="text-[var(--color-text-secondary)] transition-colors duration-200 hover:text-[var(--color-primary)]"
      aria-label="Email"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
      </svg>
    </a>
  </div>
</aside>

<!-- Mobile Top Bar -->
<nav
  id="mobile-nav"
  class="fixed top-0 left-0 right-0 z-50 border-b border-[var(--color-border)] bg-[var(--color-bg)]/90 backdrop-blur-xl lg:hidden"
>
  <div class="flex items-center justify-between px-5 py-3">
    <a href={localePath("/", locale)} class="font-bold text-[var(--color-primary)] font-[family-name:var(--font-heading)]">
      KN.
    </a>
    <div class="flex items-center gap-3">
      <LanguageSwitcher locale={locale} />
      <button
        id="mobile-theme-toggle"
        class="text-[var(--color-text-secondary)] transition-colors duration-200 hover:text-[var(--color-primary)]"
        aria-label={t("nav.ariaTheme", locale)}
      >
        <svg id="mobile-icon-sun" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
        <svg id="mobile-icon-moon" xmlns="http://www.w3.org/2000/svg" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>
      <button
        id="mobile-menu-btn"
        class="text-[var(--color-text)]"
        aria-label={t("nav.ariaMenu", locale)}
      >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
    </div>
  </div>
  <div id="mobile-menu" class="hidden max-h-[70vh] overflow-y-auto border-t border-[var(--color-border)] px-5 py-4">
    <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-[var(--color-text-secondary)]">{t("nav.resume", locale)}</p>
    {
      resumeItems.map((item) => (
        <a
          href={item.href}
          class="mobile-link block py-2 pl-2 text-sm text-[var(--color-text-secondary)] transition-colors duration-200 hover:text-[var(--color-primary)]"
        >
          {item.label}
        </a>
      ))
    }
    <a
      href={localePath("/ai-dev", locale)}
      class="mobile-link mt-4 block border-t border-[var(--color-border)] pt-4 text-xs font-semibold uppercase tracking-widest text-[var(--color-text-secondary)] transition-colors duration-200 hover:text-[var(--color-primary)]"
    >
      {t("nav.aiDev", locale)}
    </a>
    <p class="mb-3 mt-4 text-xs font-semibold uppercase tracking-widest text-[var(--color-text-secondary)]">{t("nav.projects", locale)}</p>
    {
      projectItems.map((item) => (
        <a
          href={item.href}
          class="mobile-link block py-2 pl-2 text-sm text-[var(--color-text-secondary)] transition-colors duration-200 hover:text-[var(--color-primary)]"
        >
          {item.label}
        </a>
      ))
    }
    <a
      href={localePath("/contact", locale)}
      class="mobile-link mt-4 block border-t border-[var(--color-border)] pt-4 text-xs font-semibold uppercase tracking-widest text-[var(--color-text-secondary)] transition-colors duration-200 hover:text-[var(--color-primary)]"
    >
      {t("nav.contact", locale)}
    </a>
  </div>
</nav>

<script>
  // Mobile menu toggle
  const mobileBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");

  mobileBtn?.addEventListener("click", () => {
    mobileMenu?.classList.toggle("hidden");
  });

  document.querySelectorAll(".mobile-link").forEach((link) => {
    link.addEventListener("click", () => {
      mobileMenu?.classList.add("hidden");
    });
  });

  // Collapsible sections
  function setupToggle(toggleId: string, menuId: string, chevronId: string) {
    const toggle = document.getElementById(toggleId);
    const menu = document.getElementById(menuId);
    const chevron = document.getElementById(chevronId);

    toggle?.addEventListener("click", () => {
      menu?.classList.toggle("hidden");
      chevron?.classList.toggle("rotate-180");
    });
  }

  setupToggle("resume-toggle", "resume-menu", "resume-chevron");
  setupToggle("projects-toggle", "projects-menu", "projects-chevron");

  // Theme toggle
  function updateIcons() {
    const isLight = document.documentElement.classList.contains("light");
    document.getElementById("icon-sun")?.classList.toggle("hidden", isLight);
    document.getElementById("icon-moon")?.classList.toggle("hidden", !isLight);
    document.getElementById("mobile-icon-sun")?.classList.toggle("hidden", isLight);
    document.getElementById("mobile-icon-moon")?.classList.toggle("hidden", !isLight);
  }

  function toggleTheme() {
    document.documentElement.classList.toggle("light");
    const isLight = document.documentElement.classList.contains("light");
    localStorage.setItem("theme", isLight ? "light" : "dark");
    updateIcons();
  }

  document.getElementById("theme-toggle")?.addEventListener("click", toggleTheme);
  document.getElementById("mobile-theme-toggle")?.addEventListener("click", toggleTheme);
  updateIcons();

  // Active section highlight (resume page only)
  const navLinks = document.querySelectorAll(".nav-link");
  const sections = document.querySelectorAll("section[id]");

  if (sections.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            navLinks.forEach((link) => {
              const el = link as HTMLElement;
              if (el.dataset.section === entry.target.id) {
                el.classList.add("text-[var(--color-primary)]", "bg-white/5");
                el.classList.remove("text-[var(--color-text-secondary)]");
              } else {
                el.classList.remove("text-[var(--color-primary)]", "bg-white/5");
                el.classList.add("text-[var(--color-text-secondary)]");
              }
            });
          }
        });
      },
      { rootMargin: "-20% 0px -70% 0px" },
    );

    sections.forEach((section) => observer.observe(section));
  }
</script>
