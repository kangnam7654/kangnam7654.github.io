---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/layout/Navbar.astro";
import Footer from "../components/layout/Footer.astro";
import ScrollProgress from "../components/ui/ScrollProgress.tsx";
import AiWorkflow from "../components/sections/AiWorkflow.tsx";
import { t } from "../i18n/utils";
import type { Locale } from "../i18n/utils";

const locale: Locale = "ko";
---

<BaseLayout title={`AI Dev | ${t("hero.name", locale)}`} locale={locale}>
  <ScrollProgress client:load />
  <Navbar locale={locale} />
  <main>
    <AiWorkflow client:visible locale={locale} />
  </main>
  <Footer locale={locale} />
</BaseLayout>
